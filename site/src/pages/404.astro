---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Button from "../components/ui/Button.astro";

const base = import.meta.env.BASE_URL;
---

<Base title="404 · sysdesign" description="That page isn't in the topology.">
  <Nav />
  <main id="top" class="notfound">
    <div class="wrap">
      <span class="tag">404</span>
      <h1>No route to that host.</h1>
      <p class="lead">That page isn't in the topology. Head back to the map.</p>
      <div class="cta-row">
        <Button href={base}>Back home</Button>
        <Button href="https://github.com/mkabumattar/sysdesign" variant="ghost">GitHub</Button>
      </div>
    </div>
  </main>
  <Footer />
</Base>
