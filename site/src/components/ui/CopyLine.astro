---
// A copyable slash-command line. `bare` drops the box chrome (for use inside a Terminal).
interface Props {
  id: string;
  command: string;
  label: string;
  bare?: boolean;
}
const { id, command, label, bare = false } = Astro.props;
---

<div class="cmd" style={bare ? "margin-top:0;background:transparent;border:none;padding:0 0 6px" : undefined}>
  <span class="prompt">/</span>
  <code id={id}>{command}</code>
  <button data-copy={id} aria-label={label}>copy</button>
</div>
