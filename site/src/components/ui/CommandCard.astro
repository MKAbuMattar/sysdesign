---
import type { Command } from "../../data/plugin";
interface Props { cmd: Command }
const { cmd } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<button
  class="cmdcard reveal"
  type="button"
  data-modal
  data-title={`/sysdesign:${cmd.name}`}
  data-sub={cmd.short}
  data-body={cmd.long}
  data-example={cmd.example}
  aria-haspopup="dialog"
>
  <img src={`${base}commands/${cmd.name}.svg`} alt="" width="38" height="38" />
  <div class="body">
    <div class="name">/sysdesign:<b>{cmd.name}</b></div>
    <div class="desc">{cmd.short}</div>
  </div>
</button>
