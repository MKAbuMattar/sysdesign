---
import Eyebrow from "./ui/Eyebrow.astro";
import CommandCard from "./ui/CommandCard.astro";
import { commands } from "../data/plugin";
---

<section id="commands">
  <div class="wrap">
    <Eyebrow>Eleven commands</Eyebrow>
    <h2>One skill, many intents.</h2>
    <p class="lead">
      Each command is a thin wrapper over the one <code>system-design</code> skill, so the
      reasoning stays consistent.
    </p>
    <div class="grid-cmd">
      {commands.map(([name, desc]) => <CommandCard name={name} desc={desc} />)}
    </div>
  </div>
</section>
