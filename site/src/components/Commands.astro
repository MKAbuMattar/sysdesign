---
import Eyebrow from "./ui/Eyebrow.astro";
import CommandCard from "./ui/CommandCard.astro";
import { commands } from "../data/plugin";
---

<section id="commands">
  <div class="wrap">
    <Eyebrow>Thirteen commands</Eyebrow>
    <h2>One skill, many intents.</h2>
    <p class="lead">
      Each command is a thin wrapper over the one <code>system-design</code> skill, so the
      reasoning stays consistent.
    </p>
    <div class="grid-cmd">
      {commands.map((cmd) => <CommandCard cmd={cmd} />)}
    </div>
    <p class="hint">Click a command for what it does and an example.</p>
  </div>
</section>
